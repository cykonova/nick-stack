# Runtime identity/timezone
PUID=1000
PGID=1000
TZ=America/New_York

# Host ports (container-side ports are fixed by each image)
IMMICH_PORT=2283
SYNCTHING_UI_PORT=8384
SYNCTHING_SYNC_TCP_PORT=22000
SYNCTHING_SYNC_UDP_PORT=22000
SYNCTHING_DISCOVERY_UDP_PORT=21027
FORGEJO_HTTP_PORT=3000
FORGEJO_SSH_PORT=2222
HEADSCALE_PORT=8080
NAVIDROME_PORT=4533

# Docker network subnets (adjust if colliding with LAN or other Docker projects)
EDGE_SUBNET=172.29.0.0/24
BACKEND_SUBNET=172.30.0.0/24
HARDENED_OVERLAY_SUBNET=172.31.0.0/24

# Immich
IMMICH_DB_NAME=immich
IMMICH_DB_USER=immich
IMMICH_DB_PASSWORD=change_me_immich

# Mounts
IMMICH_UPLOAD_DIR=./data/immich/upload
IMMICH_MODEL_CACHE_DIR=./data/immich/model-cache
IMMICH_POSTGRES_DATA_DIR=./data/immich/postgres
SYNCTHING_CONFIG_DIR=./data/syncthing/config
SYNCTHING_DATA_DIR=./data/syncthing/data
FORGEJO_DATA_DIR=./data/forgejo
FORGEJO_POSTGRES_DATA_DIR=./data/forgejo-postgres
HEADSCALE_DATA_DIR=./data/headscale
HEADSCALE_CONFIG_FILE=./config/headscale/config.yaml
HEADSCALE_ACL_FILE=./config/headscale/acl.hujson
NAVIDROME_DATA_DIR=./data/navidrome/data
NAVIDROME_MUSIC_DIR=./data/navidrome/music
EDGE_GATEWAY_CONFIG_FILE=./config/edge-gateway/nginx.conf
TS_STATE_DIR=./data/tailscale/state
TS_HARDENED_STATE_DIR=./data/tailscale/state-hardened

# Forgejo
FORGEJO_DB_NAME=forgejo
FORGEJO_DB_USER=forgejo
FORGEJO_DB_PASSWORD=change_me_forgejo

# Navidrome
ND_SCANSCHEDULE=1h

# Tailscale/Headscale client
TS_LOGIN_SERVER=https://headscale.example.com
TS_AUTHKEY=tskey-client-not-set
TS_HOSTNAME=nick-stack-overlay
TS_HARDENED_HOSTNAME=nick-stack-hardened
TS_ACCEPT_ROUTES=true
TS_ACCEPT_DNS=false
TS_ADVERTISE_TAGS=tag:nick-stack
